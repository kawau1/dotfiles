{
    "context": {
        "fileName": "AGENTS.md",
        "loadMemoryFromIncludeDirectories": true
    },
    "mcpServers": {},
    "tools": {
        "autoAccept": true,
        "exclude": [
            "ReadFileTool(./.env)",
            "ReadFileTool(./.env.*)",
            "ReadFileTool(./secrets/**)",
            "ReadFileTool(./config/credentials.json)",
            "ReadFileTool(./build)",
            "ReadFileTool(.ssh)",
            "ReadFileTool(id_rsa)",
            "ReadFileTool(id_ed25519)",
            "ReadFileTool(**/*token*)",
            "ReadFileTool(**/*key*)",
            "ShellTool(sudo *)",
            "ShellTool(rm *)",
            "ShellTool(rm -rf *)",
            "ShellTool(git push *)",
            "ShellTool(git commit *)",
            "ShellTool(git reset *)",
            "ShellTool(git rebase *)",
            "WriteFileTool(.env*)",
            "WriteFileTool(**/secrets/**)"
        ],
        "shell": {
            "showColor": true
        },
        "enableMessageBusIntegration": true
    },
    "general": {
        "checkpointing": {
            "enabled": true
        },
        "previewFeatures": true,
        "enablePromptCompletion": true,
        "vimMode": false,
        "plan": {
            "enabled": true
        },
        "enableNotifications": true
    },
    "ui": {
        "hideFooter": false,
        "showMemoryUsage": true,
        "showLineNumbers": true,
        "theme": "ANSI Light",
        "showStatusInTitle": true,
        "footer": {
            "hideContextPercentage": false
        },
        "showCitations": true,
        "showModelInfoInChat": true,
        "useAlternateBuffer": true,
        "inlineThinkingMode": "full",
        "escapePastedAtSymbols": true,
        "terminalBuffer": true,
        "loadingPhrases": "all"
    },
    "ide": {
        "enabled": true
    },
    "security": {
        "auth": {
            "selectedType": "oauth-personal"
        },
        "environmentVariableRedaction": {
            "enabled": true
        },
        "toolSandboxing": true,
        "enablePermanentToolApproval": true,
        "enableConseca": true
    },
    "output": {
        "format": "text"
    },
    "experimental": {
        "skills": true,
        "worktrees": true,
        "useOSC52Paste": false,
        "useOSC52Copy": false,
        "modelSteering": true,
        "memoryManager": true,
        "generalistProfile": true,
        "contextManagement": true,
        "topicUpdateNarration": true
    },
    "agents": {
        "overrides": {}
    }
}
